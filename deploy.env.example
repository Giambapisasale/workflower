# Copia in .env (accanto a docker-compose.yml) e riempi.  NON committare .env.
# --- obbligatorie ---
JWT_SECRET=cambia-questa-stringa-lunga-e-casuale
# Famiglia OpenAI gpt-5.6: T1 = "sol" (SOTA), T2 = "terra" (medio). Vision-capable.
LLM_T1_MODEL=openai/gpt-5.6-sol
LLM_T2_MODEL=openai/gpt-5.6-terra
# almeno una chiave provider, coerente con i modelli scelti
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# --- rete / TLS (Caddy) ---
# dominio per HTTPS automatico (es. demo.miosito.it) oppure :80 per la prova
SITE_ADDRESS=:80
# --- opzionali ---
LOG_LEVEL=INFO
DIAGNOSTICA_AUTO=0
# LLM_T3_MODEL=
