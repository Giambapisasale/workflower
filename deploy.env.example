# Copia in .env (accanto a docker-compose.yml) e riempi.  NON committare .env.
# --- obbligatorie ---
JWT_SECRET=cambia-questa-stringa-lunga-e-casuale
LLM_T1_MODEL=anthropic/claude-sonnet-5
LLM_T2_MODEL=anthropic/claude-haiku-4-5
# almeno una chiave provider, coerente con i modelli scelti
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# --- rete / TLS (Caddy) ---
# dominio per HTTPS automatico (es. demo.miosito.it) oppure :80 per la prova
SITE_ADDRESS=:80
# --- opzionali ---
LOG_LEVEL=INFO
DIAGNOSTICA_AUTO=0
# LLM_T3_MODEL=
