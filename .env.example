# --- LLM (litellm) ---------------------------------------------------------
# Tier T1 = SOTA (estrazione documenti, improver). Tier T2 = medio (judge, text-to-SQL).
# Qualsiasi modello supportato da litellm, es. "anthropic/claude-sonnet-5",
# "openai/gpt-5.2", "gemini/gemini-3-pro". Mai hard-codare modelli nel codice.
LLM_T1_MODEL=anthropic/claude-sonnet-5
LLM_T2_MODEL=anthropic/claude-haiku-4-5
# Tier T3 = modello locale fine-tuned (opzionale): se assente si ricade su T1.
# Punta a un endpoint locale OpenAI-compatibile (Ollama/llama.cpp/vLLM); un workflow
# instradato su T3 (tier: T3 nel manifest) gira lì e, su errore/bassa confidence/
# output fuori contratto, ESCALA a T1 (l'escalation è tracciata → % per workflow).
# Accendere solo quando l'harness (GET /api/dataset/eval-t3) dà il via libera;
# addestrare il modello con docs/finetuning-runbook.md.
#LLM_T3_MODEL=ollama/functiongemma
#LLM_T3_API_BASE=http://localhost:11434  # base_url dell'endpoint locale (litellm)

# Chiavi provider (ne basta una, coerente con i modelli scelti)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Storage ----------------------------------------------------------------
# Directory dei dati (SoT). Repo git separato, creato da `make seed`.
DATA_DIR=./data

# --- Auth -------------------------------------------------------------------
JWT_SECRET=change-me-in-production
