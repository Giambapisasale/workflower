{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rapportino",
  "description": "Rapportino giornaliero di cantiere: ore di manodopera per lavoratore",
  "type": "object",
  "additionalProperties": false,
  "required": ["cantiere_id", "data", "righe"],
  "properties": {
    "cantiere_id": { "type": "string", "pattern": "^CNT-\\d{3,}$" },
    "data": { "type": "string", "format": "date", "description": "Giorno del rapportino (ISO 8601)" },
    "righe": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["nominativo", "ore"],
        "properties": {
          "nominativo": {
            "type": "string",
            "minLength": 1,
            "description": "Nome del lavoratore o della squadra"
          },
          "mansione": {
            "type": ["string", "null"],
            "description": "Mansione svolta (muratore, manovale…); null se non indicata"
          },
          "ore": { "type": "number", "minimum": 0, "description": "Ore lavorate nella giornata" },
          "costo_orario": {
            "type": ["number", "null"],
            "description": "Costo orario in euro, se indicato; null altrimenti"
          }
        }
      }
    }
  }
}
